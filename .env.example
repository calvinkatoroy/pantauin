# Local dev (SQLite — no Docker needed)
DATABASE_URL=sqlite+aiosqlite:///./pantauin.db

# Production (PostgreSQL — use with docker-compose)
# DATABASE_URL=postgresql+asyncpg://pantauin:pantauin@postgres:5432/pantauin

GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
SECRET_KEY=dev-secret-change-in-prod
FRONTEND_URL=http://localhost:5173
EVIDENCE_DIR=./evidence

# Redis / Celery (local dev without Docker)
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Redis / Celery (docker-compose — injected automatically, no need to set here)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
