# Local dev (SQLite — no Docker needed)
DATABASE_URL=sqlite+aiosqlite:///./pantauind.db

# Production (PostgreSQL — use with docker-compose)
# DATABASE_URL=postgresql+asyncpg://pantauind:pantauind@postgres:5432/pantauind

# Serper.dev API key — used for dork sweep (Google-backed search, 2,500 free credits)
# Get yours at https://serper.dev
SERPER_API_KEY=
SECRET_KEY=dev-secret-change-in-prod

# API authentication — leave empty to disable (local dev)
API_KEY=
FRONTEND_URL=http://localhost:5173
EVIDENCE_DIR=./evidence

# Redis / Celery (local dev without Docker)
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Redis / Celery (docker-compose — injected automatically, no need to set here)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Optional: BSSN/CSIRT webhook — POST on Critical findings
WEBHOOK_URL=

# Optional: Shodan API key — passive exposed service mapping
SHODAN_API_KEY=

# Optional: Email notifications on Critical findings (SMTP with STARTTLS)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=              # comma-separated recipients

# Optional: Slack notifications on Critical findings
SLACK_WEBHOOK_URL=

# Optional: S3/R2 evidence storage
# Leave all blank to use local disk storage (default, suitable for single-node)
# For Cloudflare R2: set S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# S3_PUBLIC_URL: set to your R2 public bucket URL or custom domain to serve direct links
#                leave blank to use presigned URLs (valid for S3_PRESIGN_EXPIRY seconds)
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
S3_PRESIGN_EXPIRY=3600

# Data retention (days). Old scan records and evidence files are purged daily by Celery beat.
EVIDENCE_RETENTION_DAYS=90
SCAN_RETENTION_DAYS=365

# Subdomain enumeration (runs as part of every single-domain scan)
# SUBDOMAIN_MAX: max subdomains to enumerate per root domain (default 30)
# SUBDOMAIN_DISPATCH_SCANS: set to true to dispatch a full child scan for each live subdomain
SUBDOMAIN_MAX=30
SUBDOMAIN_DISPATCH_SCANS=false
